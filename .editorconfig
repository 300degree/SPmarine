root = true

[*.{jsx,tsx}]
charset = utf-8
indent_size = 2
max_line_length = 120
insert_final_newline = true
end_of_line = lf
indent_style = tab

[*.{js,ts}]
charset = utf-8
indent_size = 4
insert_final_newline = true
end_of_line = lf
indent_style = tab

[*.json]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2

[*.{yml,yaml}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2